<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 圆角 -->
    <corners android:radius="8dp"/>
    <!-- 激活状态背景色：红色 -->
    <solid android:color="#FFFF4444"/>
    <!-- 边框 -->
    <stroke
        android:width="2dp"
        android:color="#FFFFFFFF"/>
    <!-- 内边距 -->
    <padding
        android:left="16dp"
        android:top="8dp"
        android:right="16dp"
        android:bottom="8dp"/>
</shape>
