<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 圆角 -->
    <corners android:radius="8dp"/>
    <!-- 默认背景色：半透明灰色 -->
    <solid android:color="#80666666"/>
    <!-- 边框 -->
    <stroke
        android:width="1dp"
        android:color="#AAFFFFFF"/>
    <!-- 内边距 -->
    <padding
        android:left="16dp"
        android:top="8dp"
        android:right="16dp"
        android:bottom="8dp"/>
</shape>
